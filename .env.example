# Ratefluencer — copy this file to `.env.local` and fill in values.
# Step-by-step instructions: docs/API_KEYS.md
# In-app checklist: http://localhost:3000/settings

# ─── YouTube Data API v3 ───────────────────────────────────────────
# Guide: docs/API_KEYS.md § 1
# 1. console.cloud.google.com → project → enable "YouTube Data API v3"
# 2. APIs & Services → Credentials → Create credentials → API key
YOUTUBE_API_KEY=AIzaSyDFnRX6vxqErEZkIStXoa662MQSQ9b8VlI

# ─── Instagram Graph API (Business Discovery) ──────────────────────
# Guide: docs/API_KEYS.md § 2
# Requires: IG Professional account + Facebook Page + Meta Developer app
# META_GRAPH_ACCESS_TOKEN = Page access_token from GET /me/accounts
# INSTAGRAM_BUSINESS_ACCOUNT_ID = instagram_business_account.id (same response)
META_GRAPH_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ─── X (Twitter) API v2 ─────────────────────────────────────────────
# Guide: docs/API_KEYS.md § 3
# developer.x.com → Project → App → Keys and tokens → Bearer Token
X_API_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAALKv9wEAAAAAUV5h2d3KtzRaU%2FycTPWHHr2Hpy4%3DwrqZWM57KsfsxvCrhzcZWPTN5OSrsislTATH1IVnVldQm4U4L4
# Optional alias:
# TWITTER_BEARER_TOKEN=
