# RankMint environment — copy to .env.local (never commit secrets)

# Platform APIs (YouTube, X, Instagram — no TikTok)
YOUTUBE_API_KEY=
X_API_BEARER_TOKEN=
META_GRAPH_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Optional — higher-quality brand-match embeddings (app works without this)
# OPENAI_API_KEY=

# Optional — cache, brand workspace, saved shortlist
# URL must be project root only (no /rest/v1/ at the end)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Analysis cache TTL in hours (default 6)
ANALYSIS_CACHE_HOURS=6
